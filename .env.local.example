# Supabase Configuration (Frontend - these are public)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend Email Configuration (Server-side only - for Vercel deployment)
RESEND_API_KEY=your_resend_api_key

# Supabase Service Key (Server-side only - for Vercel deployment)
# Get this from Supabase Settings → API → Service Role Key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
